# Tissint backend production environment

# FastAPI gateway key expected in the X-API-Key header.
# Use a long random value in production and keep it server-side only.
API_KEY=change_me_to_a_long_random_secret

# Database
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=meteorite_db
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@postgres_db:5432/${DB_NAME}

# Runtime
STORAGE_DIR=/app/storage_vessel
CORS_ALLOWED_ORIGINS=*
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated test accounts allowed to scan without consuming quota.
# Keep this narrow; these accounts stay non-premium but receive unlimited scan quota.
UNLIMITED_SCAN_EMAILS=user@tissint.ma

# Set to 1 only for CI, contract export, or API smoke tests without AI inference.
TINSSIT_SKIP_MODEL_LOAD=0

# Telegram radar notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Optional app metadata used by deployment tooling.
APP_URL=https://api.tissint.ma
